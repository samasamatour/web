# Supabase Public Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role (required for admin bootstrap from allowlist)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Comma-separated admin allowlist (first-login bootstrap as admin)
CMS_ADMIN_EMAILS=owner@yourcompany.com

# Canonical site URL for SEO
NEXT_PUBLIC_SITE_URL=https://samasamatour.com
